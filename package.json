{
  "name": "figma-connect-workspace",
  "version": "0.1.0",
  "description": "Figma Connect Design System workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:demo": "npm run dev --workspace=apps/demo",
    "build:lib": "npm run build:lib --workspace=packages/figma-connect-design-system",
    "storybook": "npm run storybook --workspace=packages/figma-connect-design-system",
    "build-storybook": "npm run build-storybook --workspace=packages/figma-connect-design-system"
  },
  "devDependencies": {
    "typescript": "^5.2.2"
  }
}
